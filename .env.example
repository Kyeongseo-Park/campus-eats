# Neon Postgres — pooled connection, used by the app at runtime (src/lib/prisma.ts).
# From Neon dashboard: Connect > Pooled connection. When using the Vercel-Neon
# integration, Vercel injects this automatically as DATABASE_URL.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/campus_eats?sslmode=require"

# Neon Postgres — direct (unpooled) connection, used only by the Prisma CLI for
# migrations (prisma.config.ts). From Neon dashboard: Connect > Direct connection.
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/campus_eats?sslmode=require"

# Secret used to sign session cookies/JWTs for the custom email/password auth.
# Generate one with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Kakao Map JS SDK key (client-side map rendering). Exposed to the browser.
NEXT_PUBLIC_KAKAO_MAP_APP_KEY="your-kakao-javascript-key"

# Kakao Local REST API key (server-side, e.g. restaurant data collection / geocoding).
KAKAO_REST_API_KEY="your-kakao-rest-api-key"
