// Prisma schema for CampusEats ("학식 말고 뭐 먹지?")
// Source of truth: docs/01_PRD/PRD_v2.md, section 11 (ERD).
// Note: `Favorite` is not in the PRD's ERD table but is required to implement
// the Must-have "즐겨찾기" feature (section 5/9), so it is added here.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  nickname     String
  /// "user" | "admin" — defaults to user; admin is granted by manually updating this column.
  role         String   @default("user")
  createdAt    DateTime @default(now()) @map("created_at")

  reviews            Review[]
  restaurantRequests RestaurantRequest[]
  favorites          Favorite[]

  @@map("users")
}

model Restaurant {
  id        String @id @default(uuid()) @db.Uuid
  name      String
  /// 한식 | 중식 | 일식 | 양식 | 분식 | 카페
  category  String
  /// 정문 | 상대 | 예대 | 후문 | 공대쪽문
  zone      String
  address   String
  phone     String?
  latitude  Float
  longitude Float
  /// Lowest menu price; drives the price-range filter/sort.
  minPrice  Int    @map("min_price")

  partnershipStartDate DateTime? @map("partnership_start_date") @db.Date
  partnershipEndDate   DateTime? @map("partnership_end_date") @db.Date
  partnershipInfo      String?   @map("partnership_info")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  menus     Menu[]
  reviews   Review[]
  favorites Favorite[]

  @@index([zone])
  @@index([category])
  @@index([minPrice])
  @@index([partnershipStartDate, partnershipEndDate])
  @@map("restaurants")
}

model Menu {
  id           String @id @default(uuid()) @db.Uuid
  restaurantId String @map("restaurant_id") @db.Uuid
  name         String
  price        Int

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@map("menus")
}

model Review {
  id           String @id @default(uuid()) @db.Uuid
  userId       String @map("user_id") @db.Uuid
  restaurantId String @map("restaurant_id") @db.Uuid
  /// 1~5 정수
  rating       Int
  content      String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([userId])
  @@map("reviews")
}

model RestaurantRequest {
  id             String  @id @default(uuid()) @db.Uuid
  userId         String  @map("user_id") @db.Uuid
  restaurantName String  @map("restaurant_name")
  address        String
  /// 제보자 입력값, 관리자 승인 시 수정 가능
  category       String
  /// 선택 입력
  menuInfo       String? @map("menu_info")
  /// 대기 | 승인 | 반려
  status         String  @default("대기")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("restaurant_requests")
}

model PasswordResetRequest {
  id    String @id @default(uuid()) @db.Uuid
  email String
  /// 대기 | 처리완료
  status String @default("대기")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([status])
  @@map("password_requests")
}

model Favorite {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@map("favorites")
}
